{
  "_note": "RACI/DACI for the framework's own wave lifecycle. Accountable is always human: (EU AI Act Art 14 — a human owns each gate). Responsible are real agents from AGENT_ROSTER.md. No agent both owns and executes the same row (R3).",
  "activities": [
    {
      "id": "RA-SPEC",
      "label": "Author the master spec for a wave",
      "frame": "RACI",
      "accountable": "human:tech-lead",
      "responsible": ["chief-architect"],
      "consulted": ["micro-architect", "macro-architect", "surface-cartographer", "design-system-architect"],
      "informed": ["reflexion-critic"]
    },
    {
      "id": "RA-IMPL",
      "label": "Implement a wave to the approved spec",
      "frame": "RACI",
      "accountable": "human:tech-lead",
      "responsible": ["frontend-agent"],
      "consulted": ["chief-architect"],
      "informed": ["test-engineer"]
    },
    {
      "id": "RA-VERIFY",
      "label": "Verify a change before merge",
      "frame": "RACI",
      "accountable": "human:tech-lead",
      "responsible": ["reflexion-critic", "constitutional-reviewer"],
      "consulted": ["debate-prosecutor", "debate-defender"],
      "informed": ["debate-judge"]
    },
    {
      "id": "RA-SECURITY",
      "label": "Run the security gate on a change",
      "frame": "RACI",
      "accountable": "human:tech-lead",
      "responsible": ["security-scanner"],
      "consulted": ["pfca-agent"],
      "informed": ["meta-process-auditor"]
    },
    {
      "id": "RA-MERGE",
      "label": "Approve and trigger the merge",
      "frame": "RACI",
      "accountable": "human:tech-lead",
      "responsible": ["orchestrator"],
      "consulted": ["meta-process-auditor"],
      "informed": ["metrics-aggregator"]
    },
    {
      "id": "RA-DISCOVERY",
      "label": "Discover the product/business problem before a wave (positioning, user need, process)",
      "frame": "RACI",
      "accountable": "human:product-lead",
      "responsible": ["chief-product-officer", "product-strategist", "user-researcher"],
      "consulted": ["business-process-architect", "competitive-intelligence-officer"],
      "informed": ["chief-architect"]
    },
    {
      "id": "RA-DESIGN",
      "label": "Design the user flow, screen states, and interface copy for a wave",
      "frame": "RACI",
      "accountable": "human:tech-lead",
      "responsible": ["ux-designer", "ux-writer"],
      "consulted": ["design-system-architect"],
      "informed": ["frontend-agent"]
    },
    {
      "id": "RA-IMPL-SERVER",
      "label": "Implement the server/data side of a wave to the approved contract",
      "frame": "RACI",
      "accountable": "human:tech-lead",
      "responsible": ["backend-agent", "data-engineer"],
      "consulted": ["engineering-lead"],
      "informed": ["test-engineer"]
    },
    {
      "id": "RA-TIER1",
      "label": "Run the parallel automated quality gates after a commit",
      "frame": "RACI",
      "accountable": "human:tech-lead",
      "responsible": ["test-runner", "coverage-auditor", "a11y-auditor", "perf-profiler"],
      "consulted": ["integration-tester"],
      "informed": ["reflexion-critic"]
    },
    {
      "id": "RA-SELECT",
      "label": "Select the best of N parallel implementations",
      "frame": "RACI",
      "accountable": "human:tech-lead",
      "responsible": ["best-of-n-judge"],
      "consulted": ["reflexion-critic"],
      "informed": ["orchestrator"]
    },
    {
      "id": "RA-DEBUG",
      "label": "Triage and recover from a test/gate failure or andon halt",
      "frame": "RACI",
      "accountable": "human:tech-lead",
      "responsible": ["debug-agent"],
      "consulted": ["error-recovery-stub"],
      "informed": ["test-runner"]
    },
    {
      "id": "RA-VISUAL",
      "label": "Verify the rendered UI against the spec (visual QA)",
      "frame": "RACI",
      "accountable": "human:tech-lead",
      "responsible": ["visual-qa"],
      "consulted": ["a11y-auditor"],
      "informed": ["reflexion-critic"]
    },
    {
      "id": "RA-LEARN",
      "label": "Turn a completed wave into durable improvement (skills, cross-wave patterns)",
      "frame": "RACI",
      "accountable": "human:tech-lead",
      "responsible": ["self-improvement-reviewer", "skill-extractor"],
      "consulted": ["kaizen-officer"],
      "informed": ["proactive-surfacing-agent"]
    },
    {
      "id": "RA-SURFACE",
      "label": "Proactively surface unaddressed concerns across waves",
      "frame": "RACI",
      "accountable": "human:tech-lead",
      "responsible": ["proactive-surfacing-agent"],
      "consulted": ["meta-process-auditor"],
      "informed": ["orchestrator"]
    },
    {
      "id": "RA-DATA",
      "label": "Measure whether the product/process metric actually moved",
      "frame": "RACI",
      "accountable": "human:product-lead",
      "responsible": ["data-analyst", "data-engineer"],
      "consulted": ["data-lead"],
      "informed": ["chief-product-officer"]
    },
    {
      "id": "RA-DEPLOY",
      "label": "Ship a green build to production with a tested rollback",
      "frame": "RACI",
      "accountable": "human:tech-lead",
      "responsible": ["release-engineer"],
      "consulted": ["devops-lead"],
      "informed": ["orchestrator"]
    }
  ],
  "daci_decisions": [
    {
      "id": "DA-ARCH",
      "label": "Adopt an architecture decision (ADR)",
      "frame": "DACI",
      "driver": "chief-architect",
      "approver": "human:tech-lead",
      "contributors": ["micro-architect", "macro-architect", "surface-cartographer"],
      "informed": ["reflexion-critic"]
    }
  ]
}
