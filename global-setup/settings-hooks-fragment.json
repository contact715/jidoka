{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/jidoka-guard.sh",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node $HOME/.claude/hooks/policy-enforce-hook.mjs",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node $HOME/.claude/hooks/session-state.mjs PreToolUse",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/jidoka-feature-reminder.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "node $HOME/claude-code-dev-framework/scripts/skill-selector.mjs --hook",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "node $HOME/.claude/hooks/session-state.mjs UserPromptSubmit",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "WebFetch|WebSearch|mcp__",
        "hooks": [
          {
            "type": "command",
            "command": "node $HOME/.claude/hooks/injection-watch.mjs",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ]
  }
}
