#!/bin/sh
# Post-commit hook — non-blocking background analyses (never fails the commit).
#   - reflexion trigger: queues adversarial review when a diff is large (size-gated inside)
#   - surface-concerns: proactive surfacing on wave-boundary / L-effort commits
# Both run detached; their output goes to gitignored *-queue/ paths.
#
# PILE-UP GUARD: only launch each background job if a previous instance isn't still running.
# Without this, a hung job would accumulate one extra detached node process per commit.
ROOT="$(git rev-parse --show-toplevel)"

# 2026-06-10 — bypass audit trail: pre-commit writes .sdd-precommit-sentinel; commit-msg
# removes it when a gate refuses. Absent here = hooks were skipped (--no-verify) OR a
# sequencer op (cherry-pick / revert / rebase fires post-commit WITHOUT pre-commit — not a
# bypass). Log ONLY a real bypass, and only while hard_block_ac=true in .sdd-config.json.
# Logging every commit was the projectx gate-claims-block-but-passes incident.
# Regression test: scripts/test-sdd-hard-block.sh (T3, T6, T7)
SENTINEL_PRESENT=0
[ -f "$ROOT/.sdd-precommit-sentinel" ] && SENTINEL_PRESENT=1
rm -f "$ROOT/.sdd-precommit-sentinel" 2>/dev/null || true
GIT_DIR_PATH=$(git rev-parse --git-dir 2>/dev/null || echo "$ROOT/.git")
SEQUENCER_OP=0
if [ -f "$GIT_DIR_PATH/CHERRY_PICK_HEAD" ] || [ -f "$GIT_DIR_PATH/REVERT_HEAD" ] \
  || [ -d "$GIT_DIR_PATH/rebase-merge" ] || [ -d "$GIT_DIR_PATH/rebase-apply" ]; then
  SEQUENCER_OP=1  # plain single `git revert` may leave no marker at post-commit time — accepted residual
fi
if [ "$SENTINEL_PRESENT" -eq 0 ] && [ "$SEQUENCER_OP" -eq 0 ]; then
  HARD_BLOCK=$(SDD_CFG="$ROOT/.sdd-config.json" node -p "try{String(JSON.parse(require('fs').readFileSync(process.env.SDD_CFG,'utf8')).hard_block_ac===true)}catch{false}" 2>/dev/null || echo false)
  if [ "$HARD_BLOCK" = "true" ]; then
    HASH=$(git log --pretty=%h -1 2>/dev/null || echo unknown)
    echo "$(date -u +%Y-%m-%dT%H:%M:%SZ) commit=$HASH" >> "$ROOT/.sdd-bypass.log" 2>/dev/null || true
  fi
fi

if ! pgrep -f 'auto-reflexion-trigger.sh' >/dev/null 2>&1; then
  sh "$ROOT/scripts/auto-reflexion-trigger.sh" >/dev/null 2>&1 &
fi
if ! pgrep -f 'surface-concerns.mjs' >/dev/null 2>&1; then
  node "$ROOT/scripts/surface-concerns.mjs" >/dev/null 2>&1 &
fi
exit 0
