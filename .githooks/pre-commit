#!/bin/sh
# Pre-commit hook — fast mechanical gates before a commit lands.
#   1. meta-honesty: BLOCKS if the mistake ledger has self-confirming (garbage-in) entries.
#   2. instantiation-audit --warn: surfaces declaration-over-implementation ghosts (informational).
# Activated by: git config core.hooksPath .githooks
#
# QUIET-ON-SUCCESS: on a clean commit this prints ONE summary line per gate. The full report
# (the long advisory output) is shown ONLY when a gate actually BLOCKS. Run the scripts directly
# for the full report any time: `node scripts/meta-honesty.mjs`.
ROOT="$(git rev-parse --show-toplevel)"

out=$(node "$ROOT/scripts/meta-honesty.mjs" 2>&1); rc=$?
if [ $rc -ne 0 ]; then
  echo "$out"
  echo "✗ pre-commit BLOCKED by meta-honesty (ledger signal failed — see report above)."
  exit 1
fi
echo "✓ pre-commit · meta-honesty: ledger signal OK"

# instantiation-audit is informational — stay silent unless it actually finds ghosts.
out=$(node "$ROOT/scripts/instantiation-audit.mjs" --warn 2>&1)
if echo "$out" | grep -qE 'ghosts: [1-9]'; then
  echo "$out"
  echo "↑ instantiation-audit: ghost(s) flagged (informational, not blocking)."
else
  echo "✓ pre-commit · instantiation-audit: no ghosts"
fi

# clarify-gate — WARN by default: a staged master spec must have complete business-question
# coverage (clarify-engine). Soft trial; promote to --block via gate-graduation once stable.
out=$(node "$ROOT/scripts/clarify-gate.mjs" --staged 2>&1)
if echo "$out" | grep -q 'BUSINESS-QUESTION GATE'; then
  echo "$out"
  echo "↑ clarify-gate: under-elicited master spec flagged (WARN, not blocking)."
else
  echo "✓ pre-commit · clarify-gate: $(echo "$out" | tail -1)"
fi

# dup-guard — WARN by default: a new .mjs module re-declaring an existing export is a likely
# duplicate (survey-before-scaffold). Soft trial; promote to --block via gate-graduation.
out=$(node "$ROOT/scripts/dup-guard.mjs" --staged 2>&1)
if echo "$out" | grep -q 'SURVEY-BEFORE-SCAFFOLD'; then
  echo "$out"
  echo "↑ dup-guard: possible duplicate module flagged (WARN, not blocking)."
else
  echo "✓ pre-commit · dup-guard: $(echo "$out" | tail -1)"
fi

# 2026-06-10 — sentinel for --no-verify detection: post-commit treats its absence as a bypassed
# hook run and logs it to .sdd-bypass.log while hard_block_ac=true. Transient, gitignored.
echo "$$" > "$ROOT/.sdd-precommit-sentinel"
exit 0
